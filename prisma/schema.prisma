  storagePath         String           @map("storage_path") @db.VarChar(2000)
  cdnUrl              String?          @map("cdn_url") @db.VarChar(2000)
  externalUrl         String?          @map("external_url") @db.VarChar(2000)

  // Image dimensions
  widthPx             Int?             @map("width_px") @db.Integer
  heightPx            Int?             @map("height_px") @db.Integer
  imageVariant        ImageVariant?    @map("image_variant")
  cropInfo            Json?            @map("crop_info")

  // Video metadata
  durationSeconds     Decimal?         @map("duration_seconds") @db.Decimal(12, 3)
  resolutionLabel     String?          @map("resolution_label") @db.VarChar(20)
  frameRate           Decimal?         @map("frame_rate") @db.Decimal(6, 3)
  codec               String?          @map("codec") @db.VarChar(50)
  videoThumbnailPath  String?          @map("video_thumbnail_path") @db.VarChar(2000)

  // Document metadata
  pageCount           Int?             @map("page_count") @db.SmallInt
  ocrStatus           OcrStatus        @default(NotApplicable) @map("ocr_status")
  isSearchable        Boolean          @default(false) @map("is_searchable")

  // Descriptive metadata
  altText             String?          @map("alt_text") @db.VarChar(500)
  caption             String?          @map("caption")
  description         String?          @map("description")
  language            String?          @default("en") @map("language") @db.VarChar(10)

  // Attribution
  photographer        String?          @map("photographer") @db.VarChar(200)
  copyright           String?          @map("copyright") @db.VarChar(500)
  copyrightOwner      String?          @map("copyright_owner") @db.VarChar(200)
  license             String?          @map("license") @db.VarChar(200)

  // Valid time (when the media was originally captured)
  validFrom           DateTime?        @map("valid_from") @db.Date
  validTo             DateTime?        @map("valid_to") @db.Date

  // Display
  visibility          MediaVisibility  @default(Public) @map("visibility")
  isPrimary           Boolean          @default(false) @map("is_primary")
  displayOrder        Int              @default(0) @map("display_order") @db.SmallInt

  // Upload tracking
  uploadSource        String?          @map("upload_source") @db.VarChar(200)
  uploadedBy          String?          @map("uploaded_by") @db.Uuid

  // Timestamps
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version             Int              @default(1)
  deletedAt           DateTime?        @map("deleted_at") @db.Timestamptz
  createdBy           String?          @map("created_by") @db.Uuid

  @@index([entityType, entityId])
  @@index([entityType, entityId, isPrimary])
  @@index([entityType, entityId, displayOrder])
  @@index([assetType])
  @@index([mimeType])
  @@index([storageProvider])
  @@index([storagePath])
  @@index([checksum])
  @@index([uploadSource])
  @@index([uploadedBy])
  @@index([validFrom])
  @@index([deletedAt])
  @@map("media_assets")
}

