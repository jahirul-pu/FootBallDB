  entityId            String           @map("entity_id") @db.Uuid

  // Classification
  assetType           MediaAssetType   @map("asset_type")
  mimeType            String           @map("mime_type") @db.VarChar(100)

  // File metadata
  fileName            String           @map("file_name") @db.VarChar(500)
