datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum GeopoliticalType {
  IndependentNation
  Territory
  HistoricalState
  AdministrativeRegion
  @@map("geopolitical_type")
}

enum OrganizationType {
  Global
  Confederation
  NationalFederation
  @@map("organization_type")
}

enum TeamType {
  Club
  National
  @@map("team_type")
}

enum Gender {
  Men
  Women
  Mixed
  @@map("gender")
}

enum SurfaceType {
  Grass
  Artificial
  Hybrid
  @@map("surface_type")
}

enum FootPreference {
  Left
  Right
  Both
  @@map("foot_preference")
}

enum EntityTypeEnum {
  GeopoliticalEntity
  Organization
  Venue
  Team
  Person
  Competition
  Edition
  Match
  @@map("entity_type_enum")
}

enum AgeLevel {
  Senior
  U23
  U21
  U20
  U19
  U17
  U15
  @@map("age_level")
}

enum StageType {
  Group
  Knockout
  League
  Swiss
  Qualification
  @@map("stage_type")
}

enum TieBreakerRuleType {
  GoalDifference
  HeadToHead
  GoalsScored
  AwayGoals
  FairPlay
  Playoff
  DrawingOfLots
  @@map("tie_breaker_rule_type")
}

enum StandingStatus {
  Active
  Promoted
  Relegated
  Qualified
  Eliminated
  Champion
  @@map("standing_status")
}

enum CareerRole {
  Player
  Manager
  AssistantManager
  Coach
  GoalkeepingCoach
  SportingDirector
  Executive
  President
  Chairman
  Owner
  @@map("career_role")
}

enum EmploymentStatus {
  Permanent
  Loan
  Caretaker
  Interim
  Amateur
  YouthAcademy
  Honorary
  @@map("employment_status")
}

enum PersonRelationshipType {
  Father
  Son
  Brother
  Cousin
  Uncle
  Nephew
  Mentor
  Teacher
  Other
  @@map("person_relationship_type")
}

enum TeamRelationshipType {
  ParentClub
  ReserveTeam
  AffiliateClub
  FarmTeam
  MultiClubOwnership
  Partnership
  @@map("team_relationship_type")
}

enum LineageChangeType {
  Merger
  Split
  Relocation
  Rename
  SuccessorClub
  PhoenixClub
  Dissolution
  @@map("lineage_change_type")
}

enum FixtureStatus {
  Scheduled
  Postponed
  Cancelled
  Completed
  @@map("fixture_status")
}

enum MatchStatus {
  InProgress
  Completed
  Abandoned
  Awarded
  @@map("match_status")
}

enum OfficialRole {
  Referee
  AssistantReferee
  FourthOfficial
  VAR
  AVAR
  @@map("official_role")
}

enum MatchEventType {
  Goal
  OwnGoal
  PenaltyGoal
  PenaltyMiss
  YellowCard
  SecondYellow
  RedCard
  SubstitutionIn
  SubstitutionOut
  VARDecision
  Kickoff
  HalfTime
  FullTime
  ExtraTimeStart
  ExtraTimeEnd
  PenaltyShootoutStart
  PenaltyKick
  PenaltyShootoutEnd
  @@map("match_event_type")
}

enum RosterRole {
  Player
  Manager
  Coach
  Staff
  @@map("roster_role")
}

enum PlayerPosition {
  GK
  DEF
  MID
  FWD
  @@map("player_position")
}


model GeopoliticalEntity {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  typeCode    GeopoliticalType @map("type_code")
  primaryName String    @map("primary_name") @db.VarChar(100)
  isoCode     String?   @map("iso_code") @db.VarChar(3)
  fifaCode    String?   @map("fifa_code") @db.VarChar(3)
  validFrom   DateTime  @map("valid_from") @db.Date
  validTo     DateTime? @map("valid_to") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version     Int       @default(1)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?   @map("created_by") @db.Uuid

  organizations Organization[]
  venues        Venue[]
  teams         Team[]
  personsBorn   Person[]       @relation("PersonBirthGeo")
  editions      Edition[]

  @@index([isoCode])
  @@index([fifaCode])
  @@index([validFrom, validTo])
  @@index([deletedAt])
  @@map("geopolitical_entities")
}

model Organization {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName     String           @map("primary_name") @db.VarChar(200)
  abbreviation    String           @map("abbreviation") @db.VarChar(20)
  orgType         OrganizationType @map("org_type")
  geopoliticalId  String?          @map("geopolitical_id") @db.Uuid
  geopolitical    GeopoliticalEntity? @relation(fields: [geopoliticalId], references: [id], onDelete: Restrict)
  foundationYear  Int              @map("foundation_year") @db.SmallInt
  foundationMonth Int?             @map("foundation_month") @db.SmallInt
  foundationDay   Int?             @map("foundation_day") @db.SmallInt
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version         Int              @default(1)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz
  createdBy       String?          @map("created_by") @db.Uuid

  teams           Team[]
  competitions    Competition[]
  awards          Award[]
  records         Record[]

  @@index([geopoliticalId])
  @@index([deletedAt])
  @@map("organizations")
}

model Venue {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName    String             @map("primary_name") @db.VarChar(150)
  geopoliticalId String?            @map("geopolitical_id") @db.Uuid
  geopolitical   GeopoliticalEntity? @relation(fields: [geopoliticalId], references: [id], onDelete: Restrict)
  city           String             @map("city") @db.VarChar(100)
  latitude       Decimal?           @map("latitude") @db.Decimal(9, 6)
  longitude      Decimal?           @map("longitude") @db.Decimal(9, 6)
  capacity       Int?               @map("capacity") @db.Integer
  surface        SurfaceType        @default(Grass) @map("surface")
  validFrom      DateTime           @map("valid_from") @db.Date
  validTo        DateTime?          @map("valid_to") @db.Date
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version        Int                @default(1)
  deletedAt      DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy      String?            @map("created_by") @db.Uuid

  @@index([geopoliticalId])
  @@index([validFrom, validTo])
  @@index([deletedAt])
  @@map("venues")
}

model Team {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName             String             @map("primary_name") @db.VarChar(150)
  shortName               String?            @map("short_name") @db.VarChar(3)
  teamCategory            TeamType           @map("team_category")
  teamGender              Gender             @default(Men) @map("team_gender")
  governingOrganizationId String             @map("governing_organization_id") @db.Uuid
  governingOrganization   Organization       @relation(fields: [governingOrganizationId], references: [id], onDelete: Restrict)
  geopoliticalId          String             @map("geopolitical_id") @db.Uuid
  geopolitical            GeopoliticalEntity @relation(fields: [geopoliticalId], references: [id], onDelete: Restrict)
  foundationYear          Int                @map("foundation_year") @db.SmallInt
  foundationMonth         Int?               @map("foundation_month") @db.SmallInt
  foundationDay           Int?               @map("foundation_day") @db.SmallInt
  dissolutionYear         Int?               @map("dissolution_year") @db.SmallInt
  dissolutionMonth        Int?               @map("dissolution_month") @db.SmallInt
  dissolutionDay          Int?               @map("dissolution_day") @db.SmallInt
  createdAt               DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version                 Int                @default(1)
  deletedAt               DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy               String?            @map("created_by") @db.Uuid

  standingTables               StandingTable[]
  rosters                      Roster[]
  homeFixtures                 FixtureEvent[]             @relation("HomeFixture")
  awayFixtures                 FixtureEvent[]             @relation("AwayFixture")
  homeMatches                  Match[]                    @relation("HomeMatch")
  awayMatches                  Match[]                    @relation("AwayMatch")
  matchAppearances             MatchAppearance[]
  matchEvents                  MatchEvent[]
  careerAssociations           CareerAssociation[]
  teamRelationships            TeamRelationship[]         @relation("TeamRelA")
  relatedTeamRelationships     TeamRelationship[]         @relation("TeamRelB")
  lineageNodes                 InstitutionalLineageNode[] @relation("LineageTeam")
  predecessorNodes             InstitutionalLineageNode[] @relation("LineagePredecessor")

  @@index([governingOrganizationId])
  @@index([geopoliticalId])
  @@index([deletedAt])
  @@map("teams")
}

model Person {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName         String             @map("primary_name") @db.VarChar(200)
  birthYear           Int                @map("birth_year") @db.SmallInt
  birthMonth          Int?               @map("birth_month") @db.SmallInt
  birthDay            Int?               @map("birth_day") @db.SmallInt
  birthGeopoliticalId String?            @map("birth_geopolitical_id") @db.Uuid
  birthGeopolitical   GeopoliticalEntity? @relation("PersonBirthGeo", fields: [birthGeopoliticalId], references: [id], onDelete: Restrict)
  birthCity           String?            @map("birth_city") @db.VarChar(100)
  deathYear           Int?               @map("death_year") @db.SmallInt
  deathMonth          Int?               @map("death_month") @db.SmallInt
  deathDay            Int?               @map("death_day") @db.SmallInt
  heightCm            Int?               @map("height_cm") @db.SmallInt
  preferredFoot       FootPreference?    @map("preferred_foot")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version             Int                @default(1)
  deletedAt           DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy           String?            @map("created_by") @db.Uuid

  rosters                      Roster[]
  matchAppearances             MatchAppearance[]
  matchOfficialAssignments     MatchOfficialAssignment[]
  matchEventsActor             MatchEvent[]               @relation("EventActor")
  matchEventsRelated           MatchEvent[]               @relation("EventRelated")
  careerAssociations           CareerAssociation[]
  personRelationships          PersonRelationship[]       @relation("PersonRelA")
  relatedPersonRelationships   PersonRelationship[]       @relation("PersonRelB")

  @@index([birthGeopoliticalId])
  @@index([deletedAt])
  @@map("persons")
}

model Alias {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  EntityTypeEnum @map("entity_type")
  entityId    String         @map("entity_id") @db.Uuid
  aliasValue  String         @map("alias_value") @db.VarChar(100)
  validFrom   DateTime?      @map("valid_from") @db.Date
  validTo     DateTime?      @map("valid_to") @db.Date
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version     Int            @default(1)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz
  createdBy   String?        @map("created_by") @db.Uuid

  @@index([entityType, entityId])
  @@index([aliasValue])
  @@index([deletedAt])
  @@map("aliases")
}

model LocalizedText {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType       EntityTypeEnum @map("entity_type")
  entityId         String         @map("entity_id") @db.Uuid
  languageTag      String         @map("language_tag") @db.VarChar(20)
  fieldName        String         @map("field_name") @db.VarChar(50)
  translatedString String         @map("translated_string") @db.VarChar(255)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version          Int            @default(1)
  deletedAt        DateTime?      @map("deleted_at") @db.Timestamptz
  createdBy        String?        @map("created_by") @db.Uuid

  @@unique([entityType, entityId, languageTag, fieldName], name: "unique_localization")
  @@index([entityType, entityId])
  @@index([languageTag])
  @@index([deletedAt])
  @@map("localized_texts")
}

model Competition {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName             String       @map("primary_name") @db.VarChar(150)
  shortName               String?      @map("short_name") @db.VarChar(50)
  competitionGender       Gender       @default(Men) @map("competition_gender")
  ageCategory             AgeLevel     @default(Senior) @map("age_category")
  tier                    Int?         @map("tier") @db.SmallInt
  governingOrganizationId String       @map("governing_organization_id") @db.Uuid
  governingOrganization   Organization @relation(fields: [governingOrganizationId], references: [id], onDelete: Restrict)
  foundedYear             Int          @map("founded_year") @db.SmallInt
  abolishedYear           Int?         @map("abolished_year") @db.SmallInt
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version                 Int          @default(1)
  deletedAt               DateTime?    @map("deleted_at") @db.Timestamptz
  createdBy               String?      @map("created_by") @db.Uuid

  editions                Edition[]
  awards                  Award[]
  records                 Record[]

  @@index([governingOrganizationId])
  @@index([deletedAt])
  @@map("competitions")
}

model Season {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName String    @map("primary_name") @db.VarChar(50)
  startYear   Int       @map("start_year") @db.SmallInt
  endYear     Int       @map("end_year") @db.SmallInt
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version     Int       @default(1)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?   @map("created_by") @db.Uuid

  editions      Edition[]
  awardRecipients AwardRecipient[]

  @@index([startYear, endYear])
  @@index([deletedAt])
  @@map("seasons")
}

model Edition {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName        String              @map("primary_name") @db.VarChar(200)
  competitionId      String              @map("competition_id") @db.Uuid
  competition        Competition         @relation(fields: [competitionId], references: [id], onDelete: Restrict)
  seasonId           String              @map("season_id") @db.Uuid
  season             Season              @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  hostGeopoliticalId String?             @map("host_geopolitical_id") @db.Uuid
  hostGeopolitical   GeopoliticalEntity? @relation(fields: [hostGeopoliticalId], references: [id], onDelete: Restrict)
  startDate          DateTime?           @map("start_date") @db.Date
  endDate            DateTime?           @map("end_date") @db.Date
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version            Int                 @default(1)
  deletedAt          DateTime?           @map("deleted_at") @db.Timestamptz
  createdBy          String?             @map("created_by") @db.Uuid

  stages             Stage[]
  rosters            Roster[]
  awardRecipients    AwardRecipient[]
  recordHolders      RecordHolder[]

  @@index([competitionId])
  @@index([seasonId])
  @@index([hostGeopoliticalId])
  @@index([deletedAt])
  @@map("editions")
}

model Stage {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  editionId   String    @map("edition_id") @db.Uuid
  edition     Edition   @relation(fields: [editionId], references: [id], onDelete: Cascade)
  primaryName String    @map("primary_name") @db.VarChar(150)
  format      StageType @map("format")
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version     Int       @default(1)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?   @map("created_by") @db.Uuid

  tieBreakerRules TieBreakerRule[]
  standingTables  StandingTable[]

  @@index([editionId])
  @@index([deletedAt])
  @@map("stages")
}

model TieBreakerRule {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stageId        String             @map("stage_id") @db.Uuid
  stage          Stage              @relation(fields: [stageId], references: [id], onDelete: Cascade)
  ruleType       TieBreakerRuleType @map("rule_type")
  executionOrder Int                @map("execution_order") @db.SmallInt
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version        Int                @default(1)
  deletedAt      DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy      String?            @map("created_by") @db.Uuid

  @@unique([stageId, executionOrder], name: "unique_stage_execution_order")
  @@index([stageId])
  @@index([deletedAt])
  @@map("tie_breaker_rules")
}

model StandingTable {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stageId          String          @map("stage_id") @db.Uuid
  stage            Stage           @relation(fields: [stageId], references: [id], onDelete: Cascade)
  teamId           String          @map("team_id") @db.Uuid
  team             Team            @relation(fields: [teamId], references: [id], onDelete: Restrict)
  matchweek        Int?            @map("matchweek") @db.SmallInt
  snapshotDate     DateTime        @map("snapshot_date") @db.Date
  position         Int             @map("position") @db.SmallInt
  played           Int             @default(0) @map("played") @db.SmallInt
  won              Int             @default(0) @map("won") @db.SmallInt
  drawn            Int             @default(0) @map("drawn") @db.SmallInt
  lost             Int             @default(0) @map("lost") @db.SmallInt
  goalsFor         Int             @default(0) @map("goals_for") @db.SmallInt
  goalsAgainst     Int             @default(0) @map("goals_against") @db.SmallInt
  points           Int             @default(0) @map("points") @db.SmallInt
  pointsDeducted   Int             @default(0) @map("points_deducted") @db.SmallInt
  deductionReason  String?         @map("deduction_reason") @db.VarChar(255)
  status           StandingStatus? @map("status")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version          Int             @default(1)
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz
  createdBy        String?         @map("created_by") @db.Uuid

  @@unique([stageId, teamId, matchweek, snapshotDate], name: "idx_unique_standing_snapshot")
  @@index([stageId])
  @@index([teamId])
  @@index([snapshotDate])
  @@index([deletedAt])
  @@map("standing_tables")
}


model Roster {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  editionId    String      @map("edition_id") @db.Uuid
  edition      Edition     @relation(fields: [editionId], references: [id], onDelete: Cascade)
  teamId       String      @map("team_id") @db.Uuid
  team         Team        @relation(fields: [teamId], references: [id], onDelete: Restrict)
  personId     String      @map("person_id") @db.Uuid
  person       Person      @relation(fields: [personId], references: [id], onDelete: Restrict)
  shirtNumber  Int?        @map("shirt_number") @db.SmallInt
  role         RosterRole  @default(Player) @map("role")
  position     PlayerPosition? @map("position")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version      Int         @default(1)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz
  createdBy    String?     @map("created_by") @db.Uuid

  @@unique([editionId, teamId, personId], name: "unique_roster_member")
  @@index([editionId])
  @@index([teamId])
  @@index([personId])
  @@index([deletedAt])
  @@map("rosters")
}

model FixtureEvent {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stageId       String?        @map("stage_id") @db.Uuid
  stage         Stage?         @relation(fields: [stageId], references: [id], onDelete: Restrict)
  homeTeamId    String?        @map("home_team_id") @db.Uuid
  homeTeam      Team?          @relation("HomeFixture", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeamId    String?        @map("away_team_id") @db.Uuid
  awayTeam      Team?          @relation("AwayFixture", fields: [awayTeamId], references: [id], onDelete: Restrict)
  venueId       String?        @map("venue_id") @db.Uuid
  venue         Venue?         @relation(fields: [venueId], references: [id], onDelete: Restrict)
  scheduledTime DateTime?      @map("scheduled_time") @db.Timestamptz
  status        FixtureStatus  @default(Scheduled) @map("status")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version       Int            @default(1)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz
  createdBy     String?        @map("created_by") @db.Uuid

  match         Match?

  @@index([stageId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledTime])
  @@index([deletedAt])
  @@map("fixture_events")
}

model Match {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fixtureEventId   String?      @unique @map("fixture_event_id") @db.Uuid
  fixtureEvent     FixtureEvent? @relation(fields: [fixtureEventId], references: [id], onDelete: Restrict)
  homeTeamId       String       @map("home_team_id") @db.Uuid
  homeTeam         Team         @relation("HomeMatch", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeamId       String       @map("away_team_id") @db.Uuid
  awayTeam         Team         @relation("AwayMatch", fields: [awayTeamId], references: [id], onDelete: Restrict)
  venueId          String?      @map("venue_id") @db.Uuid
  venue            Venue?       @relation(fields: [venueId], references: [id], onDelete: Restrict)
  kickoffTime      DateTime?    @map("kickoff_time") @db.Timestamptz
  homeScore        Int?         @map("home_score") @db.SmallInt
  awayScore        Int?         @map("away_score") @db.SmallInt
  homePenaltyScore Int?         @map("home_penalty_score") @db.SmallInt
  awayPenaltyScore Int?         @map("away_penalty_score") @db.SmallInt
  attendance       Int?         @map("attendance") @db.Integer
  status           MatchStatus  @default(Completed) @map("status")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version          Int          @default(1)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz
