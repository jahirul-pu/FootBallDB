  @@index([recipientType, recipientId])
  @@index([editionId])
  @@index([seasonId])
  @@index([matchId])
  @@index([awardYear])
  @@index([awardId, isWinner])
  @@index([deletedAt])
  @@map("award_recipients")
}

model Record {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryName             String                   @map("primary_name") @db.VarChar(300)
  category                RecordCategory           @map("category")
  measurementType         RecordMeasurementType    @map("measurement_type")
  unit                    String?                  @map("unit") @db.VarChar(50)
  recordValue             Decimal?                 @map("record_value") @db.Decimal(20, 6)
  description             String?                  @map("description")
  governingOrganizationId String?                  @map("governing_organization_id") @db.Uuid
  governingOrganization   Organization?            @relation(fields: [governingOrganizationId], references: [id], onDelete: Restrict)
  competitionId           String?                  @map("competition_id") @db.Uuid
  competition             Competition?             @relation(fields: [competitionId], references: [id], onDelete: Restrict)
  effectiveFrom           DateTime?                @map("effective_from") @db.Date
  effectiveTo             DateTime?                @map("effective_to") @db.Date
  verificationStatus      RecordVerificationStatus @default(Unverified) @map("verification_status")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version                 Int                      @default(1)
  deletedAt               DateTime?                @map("deleted_at") @db.Timestamptz
  createdBy               String?                  @map("created_by") @db.Uuid

  holders                 RecordHolder[]

  @@index([category])
  @@index([measurementType])
  @@index([governingOrganizationId])
  @@index([competitionId])
  @@index([verificationStatus])
  @@index([effectiveFrom, effectiveTo])
  @@index([deletedAt])
  @@map("records")
}

model RecordHolder {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId    String           @map("record_id") @db.Uuid
  record      Record           @relation(fields: [recordId], references: [id], onDelete: Restrict)
  holderType  RecordHolderType @map("holder_type")
  holderId    String           @map("holder_id") @db.Uuid
  startYear   Int?             @map("start_year") @db.SmallInt
  startMonth  Int?             @map("start_month") @db.SmallInt
  startDay    Int?             @map("start_day") @db.SmallInt
  endYear     Int?             @map("end_year") @db.SmallInt
  endMonth    Int?             @map("end_month") @db.SmallInt
  endDay      Int?             @map("end_day") @db.SmallInt
  isCurrent   Boolean          @default(false) @map("is_current")
  isShared    Boolean          @default(false) @map("is_shared")
  editionId   String?          @map("edition_id") @db.Uuid
  edition     Edition?         @relation(fields: [editionId], references: [id], onDelete: Restrict)
  matchId     String?          @map("match_id") @db.Uuid
  match       Match?           @relation(fields: [matchId], references: [id], onDelete: Restrict)
  notes       String?          @map("notes")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  version     Int              @default(1)
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz
  createdBy   String?          @map("created_by") @db.Uuid

  @@index([recordId])
  @@index([holderType, holderId])
  @@index([recordId, isCurrent])
  @@index([editionId])
  @@index([matchId])
  @@index([startYear, startMonth])
  @@index([deletedAt])
  @@map("record_holders")
}
